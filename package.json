{
  "name": "mystrip",
  "version": "1.0.0",
  "description": "AI-powered travel planner for Jaipur",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm run dev",
    "install-all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "mongoose": "^8.3.4",
    "nodemon": "^3.1.0",
    "@google/generative-ai": "^0.15.0"
  }
}
